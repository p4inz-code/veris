{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@veris/core": ["./packages/core/src"],
      "@veris/core/*": ["./packages/core/src/*"],
      "@veris/shared": ["./packages/shared/src"],
      "@veris/shared/*": ["./packages/shared/src/*"],
      "@veris/logger": ["./packages/logger/src"],
      "@veris/config": ["./packages/config/src"],
      "@veris/telemetry": ["./packages/telemetry/src"],
      "@veris/ai": ["./packages/ai/src"],
      "@veris/discovery": ["./packages/discovery/src"],
      "@veris/classification": ["./packages/classification/src"],
      "@veris/extractors": ["./packages/extractors/src"],
      "@veris/rules-engine": ["./packages/rules-engine/src"],
      "@veris/rules": ["./packages/rules/src"],
      "@veris/knowledge": ["./packages/knowledge/src"],
      "@veris/analyzer": ["./packages/analyzer/src"],
      "@veris/report": ["./packages/report/src"],
      "@veris/exporters": ["./packages/exporters/src"],
      "@veris/renderers": ["./packages/renderers/src"],
      "@veris/cli": ["./packages/cli/src"],
      "@veris/api": ["./packages/api/src"],
      "@veris/runners": ["./packages/runners/src"],
      "@veris/plugins": ["./packages/plugins/src"],
      "@veris/plugin-sdk": ["./packages/plugin-sdk/src"],
      "@veris/correlation": ["./packages/correlation/src"],
      "@veris/risk": ["./packages/risk/src"],
      "@veris/recommendations": ["./packages/recommendations/src"],
      "@veris/explain": ["./packages/explain/src"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.bench.ts"
  ]
}

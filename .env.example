# VERIS Environment Configuration
# Copy this file to .env and fill in your values

# Logging
# VERIS_LOG_LEVEL=info

# Telemetry (optional)
# VERIS_TELEMETRY_ENABLED=false
# VERIS_OTLP_ENDPOINT=

# AI Providers (optional)
# VERIS_OPENAI_API_KEY=
# VERIS_ANTHROPIC_API_KEY=

# Plugin directory (optional, defaults to ~/.veris/plugins)
# VERIS_PLUGIN_DIR=

# Config file path (optional)
# VERIS_CONFIG_PATH=

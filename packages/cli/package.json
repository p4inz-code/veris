{
  "name": "veris",
  "version": "0.1.3",
  "description": "VERIS CLI — scan, report, init, validate, version, completions",
  "license": "UNLICENSED",
  "author": "VERIS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "veris": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "node -e \"const fs=require('fs');const orig=fs.readFileSync('./package.json','utf8');fs.writeFileSync('./.package.json.bak',orig);const p=JSON.parse(orig);delete p.devDependencies;fs.writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "postpack": "node -e \"if(require('fs').existsSync('./.package.json.bak')){const orig=require('fs').readFileSync('./.package.json.bak','utf8');require('fs').writeFileSync('./package.json',orig);require('fs').unlinkSync('./.package.json.bak')}\""
  },
  "dependencies": {},
  "devDependencies": {
    "@veris/core": "workspace:*",
    "@veris/shared": "workspace:*",
    "@veris/analyzer": "workspace:*",
    "@veris/pipeline": "workspace:*",
    "@veris/report": "workspace:*",
    "@veris/exporters": "workspace:*",
    "@veris/config": "workspace:*",
    "@veris/logger": "workspace:*",
    "@veris/telemetry": "workspace:*",
    "@veris/ai": "workspace:*",
    "@veris/renderers": "workspace:*",
    "@veris/runners": "workspace:*",
    "@veris/explain": "workspace:*",
    "@veris/discovery": "workspace:*",
    "@veris/classification": "workspace:*",
    "@veris/extractors": "workspace:*",
    "@veris/knowledge": "workspace:*",
    "@veris/analysis": "workspace:*",
    "@veris/rules": "workspace:*",
    "@veris/correlation": "workspace:*",
    "@veris/risk": "workspace:*",
    "@veris/recommendations": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/veris/veris.git"
  },
  "homepage": "https://github.com/veris/veris",
  "bugs": {
    "url": "https://github.com/veris/veris/issues"
  },
  "keywords": [
    "security",
    "malware",
    "forensics",
    "analysis",
    "deterministic",
    "scanner",
    "typescript",
    "cli",
    "command-line"
  ],
  "publishConfig": {
    "access": "public"
  }
}
